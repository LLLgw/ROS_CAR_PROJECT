<?xml version="1.0"?>
<robot name="robot">

    <link name="base_footprint"/>

    <!--base link-->
    <link name="base_link">
        <visual>
            <origin xyz=" 0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.58 0.45 0.13"/>
            </geometry>
            <material name="red">
            <color rgba="1.0 0.0 0.0 0.8" /> 
            </material>
        </visual>
        <visual>
            <origin xyz="0.22 0.0 0.2" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.02" length="0.25"/>
            </geometry>
            <material name="black">
                <color rgba="0.2 0.2 0.2 0.5"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.58 0.45 0.13"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="40.0"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <inertia ixx="0.7313" ixy="0.0" ixz="0.0"
                iyy="1.1777" iyz="0.0"
                izz="1.7963"/>
        </inertial>
    </link>

    <!--imu link-->
    <link name="imu_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.02 0.02 0.02"/>
            </geometry>
        </visual>
    </link>

    <!--laser link-->
    <link name="laser_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.07" radius="0.05"/>
            </geometry>
            <material name="black">
                <color rgba="0.75 0.75 0.75 1.0" /> 
            </material>
        </visual>
    </link>

    <!--front_left_wheel-->
    <link name="front_left_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.076" length="0.06"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.076" length="0.06"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <inertia ixx="0.001744" ixy="0.0" ixz="0.0"
                    iyy="0.001744" iyz="0.0"
                    izz="0.002888"/>
        </inertial>
    </link>

    <!--front_right_wheel-->
    <link name="front_right_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.076" length="0.06"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.076" length="0.06"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <inertia ixx="0.001744" ixy="0.0" ixz="0.0"
                    iyy="0.001744" iyz="0.0"
                    izz="0.002888"/>
        </inertial>
    </link>

    <!--back_left_wheel-->
    <link name="back_left_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.076" length="0.06"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.076" length="0.06"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <inertia ixx="0.001744" ixy="0.0" ixz="0.0"
                    iyy="0.001744" iyz="0.0"
                    izz="0.002888"/>
        </inertial>
    </link>

    <!--back_right_wheel-->
    <link name="back_right_wheel">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.076" length="0.06"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
            <geometry>
            <cylinder radius="0.076" length="0.06"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <inertia ixx="0.001744" ixy="0.0" ixz="0.0"
                    iyy="0.001744" iyz="0.0"
                    izz="0.002888"/>
        </inertial>
    </link>

    <!--imu joint-->
    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0.0 0.0 0.10" rpy="0.0 0.0 0.0"/>
    </joint>
    
    <!-- laser joint-->
    <joint name="laser_joint" type="fixed">
        <parent link="base_link"/>
        <child link="laser_link"/>
        <origin xyz="0.22 0.0 0.3535" rpy="0.0 0.0 0.0"/>
    </joint>

    <!--front_left_wheel-->
    <joint name="front_left_joint" type="fixed">
        <parent link="base_link"/>
        <child link="front_left_wheel"/>
        <origin xyz="0.2 0.225 0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1 0.0"/>
    </joint>

    <!--front_right_wheel-->
    <joint name="front_right_joint" type="fixed">
        <parent link="base_link"/>
        <child link="front_right_wheel"/>
        <origin xyz="0.2 -0.225 0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1 0.0"/>
    </joint>

    <!--back_left_wheel-->
    <joint name="back_left_joint" type="fixed">
        <parent link="base_link"/>
        <child link="back_left_wheel"/>
        <origin xyz="-0.2 0.225 0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1 0.0"/>
    </joint>

    <!--back_right_wheel-->
    <joint name="back_right_joint" type="fixed">
        <parent link="base_link"/>
        <child link="back_right_wheel"/>
        <origin xyz="-0.2 -0.225 0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1 0.0"/>
    </joint>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0.0 0.0 0.08" rpy="0.0 0.0 0.0"/>
    </joint>

</robot>